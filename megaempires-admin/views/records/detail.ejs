<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Mega Empires Admin</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <!-- SweetAlert2 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
    <!-- Custom CSS -->
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="bi bi-trophy"></i> Mega Empires Admin
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">
                            <i class="bi bi-house"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-controller"></i> Games
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/games">View All Games</a></li>
                            <li><a class="dropdown-item" href="/games/new">Add New Game</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-people"></i> Players
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/players">View All Players</a></li>
                            <li><a class="dropdown-item" href="/players/new">Add New Player</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-flag"></i> Nations
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/nations">View All Nations</a></li>
                            <li><a class="dropdown-item" href="/nations/new">Add New Nation</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle active" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-table"></i> Records
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/records">View All Records</a></li>
                            <li><a class="dropdown-item" href="/records/new">Add New Record</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="container mt-4">
        <!-- Page Header -->
        <div class="row mb-4">
            <div class="col">
                <h1 class="h2"><%= title %></h1>
            </div>
        </div>

        <!-- Breadcrumb -->
        <div class="row mb-3">
            <div class="col">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/records">Records</a></li>
                        <li class="breadcrumb-item"><a href="/games/<%= record.game_id %>"><%= record.game_name %></a></li>
                        <li class="breadcrumb-item active" aria-current="page"><%= record.player_display || record.player_name %></li>
                    </ol>
                </nav>
            </div>
        </div>

        <!-- Record Actions -->
        <div class="row mb-3">
            <div class="col">
                <div class="btn-group">
                    <a href="/records/<%= record.game_id %>/<%= record.player_id %>/<%= record.nation_id %>/edit" class="btn btn-primary">
                        <i class="bi bi-pencil"></i> Edit Record
                    </a>
                    <button type="button" class="btn btn-outline-danger"
                            onclick="confirmDelete(<%= record.game_id %>, <%= record.player_id %>, <%= record.nation_id %>)">
                        <i class="bi bi-trash"></i> Delete Record
                    </button>
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <!-- Basic Information -->
            <div class="col-lg-8">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-info-circle"></i> Basic Information
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4">
                                <h6>Game</h6>
                                <p><a href="/games/<%= record.game_id %>"><%= record.game_name %></a></p>
                            </div>
                            <div class="col-md-4">
                                <h6>Date</h6>
                                <p class="text-muted">
                                    <% if (record.game_date) { %>
                                        <span class="badge bg-light text-dark"><%= record.game_date %></span>
                                    <% } else { %>
                                        <span class="text-muted">Not recorded</span>
                                    <% } %>
                                </p>
                            </div>
                            <div class="col-md-4">
                                <h6>Player</h6>
                                <p><a href="/players/<%= record.player_id %>"><%= record.player_display || record.player_name %></a></p>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4">
                                <h6>Nation</h6>
                                <p><a href="/nations/<%= record.nation_id %>"><span class="badge bg-primary fs-6"><%= record.nation_name %></span></a></p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Game Results -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-trophy"></i> Game Results
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4">
                                <h6>Final Score</h6>
                                <p>
                                    <% if (record.score != null) { %>
                                        <span class="badge bg-success fs-5"><%= record.score %></span>
                                    <% } else { %>
                                        <span class="text-muted">Not recorded</span>
                                    <% } %>
                                </p>
                            </div>
                            <div class="col-md-4">
                                <h6>AST Position</h6>
                                <p>
                                    <% if (record.ast_pos != null) { %>
                                        <span class="badge bg-info fs-6"><%= record.ast_pos %></span>
                                    <% } else { %>
                                        <span class="text-muted">Not recorded</span>
                                    <% } %>
                                </p>
                            </div>
                            <div class="col-md-4">
                                <h6>Cities</h6>
                                <p>
                                    <% if (record.cities != null) { %>
                                        <span class="badge bg-secondary fs-6"><%= record.cities %></span>
                                    <% } else { %>
                                        <span class="text-muted">Not recorded</span>
                                    <% } %>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Civilization Advances -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-lightbulb"></i> Civilization Advances
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4">
                                <h6>1VP Advances</h6>
                                <p><span class="badge bg-light text-dark fs-6"><%= record.num_civ_adv_1VP || 0 %></span></p>
                            </div>
                            <div class="col-md-4">
                                <h6>3VP Advances</h6>
                                <p><span class="badge bg-light text-dark fs-6"><%= record.num_civ_adv_3VP || 0 %></span></p>
                            </div>
                            <div class="col-md-4">
                                <h6>6VP Advances</h6>
                                <p><span class="badge bg-light text-dark fs-6"><%= record.num_civ_adv_6VP || 0 %></span></p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Special Achievements -->
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-star"></i> Special Achievements
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-3">
                                <h6>Special Building in Region</h6>
                                <p>
                                    <% if (record.special_building) { %>
                                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> Yes</span>
                                    <% } else { %>
                                        <span class="badge bg-light text-dark"><i class="bi bi-x-circle"></i> No</span>
                                    <% } %>
                                </p>
                            </div>
                            <div class="col-md-3">
                                <h6>Control Historical Building</h6>
                                <p>
                                    <% if (record.special_building_own) { %>
                                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> Yes</span>
                                    <% } else { %>
                                        <span class="badge bg-light text-dark"><i class="bi bi-x-circle"></i> No</span>
                                    <% } %>
                                </p>
                            </div>
                            <div class="col-md-3">
                                <h6>Buildings Controlled</h6>
                                <p><span class="badge bg-light text-dark fs-6"><%= record.special_building_control || 0 %></span></p>
                            </div>
                            <div class="col-md-3">
                                <h6>Bonus VP</h6>
                                <p>
                                    <% if (record.bonus_vp) { %>
                                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> Yes</span>
                                    <% } else { %>
                                        <span class="badge bg-light text-dark"><i class="bi bi-x-circle"></i> No</span>
                                    <% } %>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Score Summary -->
            <div class="col-lg-4">
                <div class="card">
                    <div class="card-header">
                        <h6 class="card-title mb-0">
                            <i class="bi bi-calculator"></i> Score Breakdown
                        </h6>
                    </div>
                    <div class="card-body">
                        <%
                            var astVP = record.ast_pos > 0 ? (record.ast_pos - 1) * 5 : 0;
                            var adv1 = record.num_civ_adv_1VP || 0;
                            var adv3 = (record.num_civ_adv_3VP || 0) * 3;
                            var adv6 = (record.num_civ_adv_6VP || 0) * 6;
                            var specialVP = (record.special_building ? 2 : 0) + (record.special_building_own ? 2 : 0) + (record.special_building_control || 0);
                        %>
                        <div class="small">
                            <div class="row mb-2">
                                <div class="col-8">AST (<%= record.ast_pos || 0 %> pos):</div>
                                <div class="col-4 text-end"><%= astVP %></div>
                            </div>
                            <div class="row mb-2">
                                <div class="col-8">Cities:</div>
                                <div class="col-4 text-end"><%= record.cities || 0 %></div>
                            </div>
                            <div class="row mb-2">
                                <div class="col-8">1VP Advances (<%= record.num_civ_adv_1VP || 0 %>):</div>
                                <div class="col-4 text-end"><%= adv1 %></div>
                            </div>
                            <div class="row mb-2">
                                <div class="col-8">3VP Advances (<%= record.num_civ_adv_3VP || 0 %>):</div>
                                <div class="col-4 text-end"><%= adv3 %></div>
                            </div>
                            <div class="row mb-2">
                                <div class="col-8">6VP Advances (<%= record.num_civ_adv_6VP || 0 %>):</div>
                                <div class="col-4 text-end"><%= adv6 %></div>
                            </div>
                            <div class="row mb-2">
                                <div class="col-8">Special Buildings:</div>
                                <div class="col-4 text-end"><%= specialVP %></div>
                            </div>
                            <hr>
                            <div class="row">
                                <div class="col-8"><strong>Recorded Score:</strong></div>
                                <div class="col-4 text-end"><strong><%= record.score != null ? record.score : '-' %></strong></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-light mt-5 py-4">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <p class="text-muted mb-0">
                        <i class="bi bi-trophy"></i> Mega Empires Database Admin Interface
                    </p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p class="text-muted mb-0">
                        Built with Node.js & Express
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/js/app.js"></script>

    <script>
        function confirmDelete(gameId, playerId, nationId) {
            Swal.fire({
                title: 'Delete Record?',
                text: 'Are you sure you want to delete this record? This action cannot be undone.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, delete it!',
                cancelButtonText: 'Cancel'
            }).then(function(result) {
                if (result.isConfirmed) {
                    var form = document.createElement('form');
                    form.method = 'POST';
                    form.action = '/records/' + gameId + '/' + playerId + '/' + nationId + '/delete';
                    document.body.appendChild(form);
                    form.submit();
                }
            });
        }
    </script>
</body>
</html>
